# ============================================
# SENTINEL AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in values.

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=sentinel_ai

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Application
API_VERSION=v1
APP_ENV=development

# AI Moderation & Explainability (Optional - system falls back to premium local models if keys are blank)
OPENAI_API_KEY=
GEMINI_API_KEY=
USE_AI_MODERATION=true
AI_PROVIDER=auto

